          <mxGeometry x="290" y="110" width="160" height="120" as="geometry" />
        </mxCell>

        <!-- Step 3: Scoring -->
        <mxCell id="step3" value="3. Word Importance&lt;br&gt;&lt;br&gt;&lt;font size=&quot;1&quot; style=&quot;font-weight: normal;&quot;&gt;Translates human words into mathematical scores based on how uniquely they appear in spam.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="500" y="110" width="160" height="120" as="geometry" />
